{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "exactOptionalPropertyTypes": true,
    "lib": [
      "ESNext"
    ],
    "module": "Node16",
    "moduleResolution": "Node16",
    "noImplicitReturns": true,
    "noEmit": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": [
      "node",
      "mocha"
    ]
  },
  "include": [
    "bin/variety",
    "cli/**/*.js",
    "core/config.js",
    "mongo-shell/launcher.js",
    ".eslint.config.js",
    "build.js",
    "test/**/*.js",
    "test/**/*.d.ts"
  ]
}
