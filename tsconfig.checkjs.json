{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "lib": [
      "ESNext"
    ],
    "module": "Node16",
    "moduleResolution": "Node16",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": [
      "node"
    ]
  },
  "include": [
    "spec/utils/**/*.js",
    "spec/utils/**/*.d.ts"
  ]
}
